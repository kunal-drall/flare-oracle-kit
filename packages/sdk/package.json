{
  "name": "@flare-oracle-kit/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Flare Network enshrined oracles (FTSO v2 and FDC)",
  "keywords": ["flare", "ftso", "oracle", "blockchain", "typescript", "web3", "defi"],
  "license": "Apache-2.0",
  "author": "XXIX Labs (29Projects)",
  "repository": {
    "type": "git",
    "url": "https://github.com/XXIX-labs/flare-oracle-kit",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "LIVE_TEST=1 vitest run tests/integration",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@flarenetwork/flare-periphery-contract-artifacts": "^0.1.41",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": { "optional": false }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
